        <Language name="treesitter.elixir" ext="ex exs" commentLine="#">
            <Keywords name="instre1">after and case catch cond def defcallback defdelegate defexception defguard defimpl defmacro defmacrop defmodule defn defnp defoverridable defp defprotocol defstruct do else end false fn for if import in nil not or quote raise receive require rescue super true try unless unquote use when with</Keywords>
        </Language>

        <!-- Zig -->
        <Language name="treesitter.zig" ext="zig" commentLine="//">
